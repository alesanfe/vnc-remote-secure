# ============================================================================
# ENVIRONMENT VARIABLES EXAMPLE
# ============================================================================
# Copy this file to .env and customize the values for your setup

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================

# Password for ttyd authentication
TTYD_PASSWD=YourStrongPassword123

# ============================================================================
# OPTIONAL VARIABLES
# ============================================================================

# Username for ttyd authentication (default: current user)
TTYD_USERNAME=$(whoami)

# Temporary user name for remote access (default: remote)
TEMP_USER=remote

# Temporary user password (default: TTYD_PASSWD)
TEMP_USER_PASS=YourStrongPassword123

# Email for SSL certificate (default: user@example.com)
EMAIL=your-email@example.com

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Port for noVNC (default: 6080)
NOVNC_PORT=6080

# Port for ttyd (default: 5000)
TTYD_PORT=5000

# Port for VNC (default: 5901)
VNC_PORT=5901

# ============================================================================
# NGINX REVERSE PROXY CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable nginx reverse proxy (default: false)
# When enabled, nginx will handle SSL and route traffic to services
# Services will bind to localhost only, improving security
NGINX_ENABLED=false

# Nginx port for HTTP (default: 80)
NGINX_HTTP_PORT=80

# Nginx port for HTTPS (default: 443)
NGINX_HTTPS_PORT=443

# ============================================================================
# SSL/TLS CONFIGURATION
# ============================================================================

# Domain for SSL certificate (required for SSL)
# Example: mydomain.duckdns.org
DUCK_DOMAIN=

# Directory for SSL certificates (default: ./ssl)
SSL_DIR=./ssl

# Days before SSL expiration to renew (default: 30)
SSL_RENEW_DAYS=30

# ============================================================================
# BEEF CONFIGURATION (OPTIONAL - FOR SECURITY TESTING ONLY)
# ============================================================================

# Enable BeEF injection (default: false)
# WARNING: Only use for authorized security testing
BEEF_ENABLED=false

# URL for BeEF hook script
BEEF_HOOK_URL=

# noVNC index file path (default: /usr/share/novnc/index.html)
INDEX_FILE=/usr/share/novnc/index.html

# noVNC VNC file path (default: /usr/share/novnc/vnc.html)
VNC_FILE=/usr/share/novnc/vnc.html

# ============================================================================
# DISCORD NOTIFICATIONS (OPTIONAL)
# ============================================================================

# Enable Discord notifications (default: false)
DISCORD_ENABLED=false

# Discord webhook URL (required if DISCORD_ENABLED=true)
# Create a webhook in your Discord server settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# ============================================================================
# FAIL2BAN CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable Fail2ban protection (default: false)
FAIL2BAN_ENABLED=false

# Maximum retry attempts before ban (default: 5)
FAIL2BAN_MAX_RETRY=5

# Time window for retries in seconds (default: 600 = 10 minutes)
FAIL2BAN_FINDTIME=600

# Ban duration in seconds (default: 3600 = 1 hour)
FAIL2BAN_BANTIME=3600

# ============================================================================
# PORT KNOCKING CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable Port Knocking (default: false)
PORT_KNOCK_ENABLED=false

# Knock sequence (comma-separated ports)
PORT_KNOCK_SEQUENCE=1000,2000,3000

# Knock timeout in seconds (default: 5)
PORT_KNOCK_TIMEOUT=5

# Knock method (iptables or nftables)
PORT_KNOCK_METHOD=iptables

# Network interface for port knocking (default: eth0)
# Common values: eth0, wlan0, ens33, enp0s3
PORT_KNOCK_INTERFACE=eth0

# ============================================================================
# MONITORING CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable Prometheus + Grafana monitoring (default: false)
MONITORING_ENABLED=false

# Prometheus port (default: 9090)
PROMETHEUS_PORT=9090

# Grafana port (default: 3000)
GRAFANA_PORT=3000

# Node Exporter port (default: 9100)
NODE_EXPORTER_PORT=9100

# ============================================================================
# HEALTHCHECK CONFIGURATION
# ============================================================================

# Enable health checks (default: true)
HEALTHCHECK_ENABLED=true

# Health check interval in seconds (default: 30)
HEALTHCHECK_INTERVAL=30

# Auto-restart failed services (default: false)
AUTO_RESTART=false

# ============================================================================
# SESSION RECORDING CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable session recording (default: false)
RECORDING_ENABLED=false

# Recording directory (default: ./recordings)
RECORDING_DIR=./recordings

# Recording format (asciinema or script)
RECORDING_FORMAT=asciinema

# ============================================================================
# USER MANAGEMENT UI CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable User Management UI (default: false)
USER_UI_ENABLED=false

# User UI port (default: 8081)
USER_UI_PORT=8081

# User UI admin password
USER_UI_PASSWORD=admin123

# Flask secret key (auto-generated if not set)
# IMPORTANT: Set a strong random key in production for security
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ============================================================================
# ALERTS CONFIGURATION (OPTIONAL)
# ============================================================================

# Enable webhook/email alerts (default: false)
ALERTS_ENABLED=false

# Webhook URL for alerts
ALERT_WEBHOOK_URL=

# Email recipient for alerts
ALERT_EMAIL_TO=

# Email sender for alerts
ALERT_EMAIL_FROM=vnc-alerts@localhost

# SMTP server for email alerts
ALERT_SMTP_SERVER=localhost:587

# SMTP username (if authentication required)
ALERT_SMTP_USER=

# SMTP password (if authentication required)
ALERT_SMTP_PASS=

# ============================================================================
# VNC SERVER CONFIGURATION
# ============================================================================

# VNC display number (default: :2)
VNC_DISPLAY=:2

# VNC resolution (default: 1920x1080)
VNC_GEOMETRY=1920x1080

# VNC color depth (default: 24)
VNC_DEPTH=24

# VNC password (default: YourStrongPassword123)
VNC_PASSWORD=YourStrongPassword123

# ============================================================================
# RUNTIME STATE (INTERNAL - DO NOT MODIFY)
# ============================================================================

# Disable SSL flag (automatically set by script, do not modify manually)
DISABLE_SSL=false

# Show logs in real-time (default: true)
SHOW_LOGS=true

# Log directory for service logs (default: ./logs)
LOG_DIR=./logs

# ============================================================================
# ADVANCED CONFIGURATION (OPTIONAL)
# ============================================================================

# Log level (debug, info, warn, error) - default: info
LOG_LEVEL=info

# Connection timeout in seconds (default: 30)
CONNECTION_TIMEOUT=30

# Maximum number of concurrent connections (default: 10)
MAX_CONNECTIONS=10

# Enable verbose output (default: false)
VERBOSE=false

# Skip dependency installation (default: false)
SKIP_DEPS=false

# Keep temporary user on exit (default: false)
KEEP_TEMP_USER=false

# Auto-start services on boot (default: false)
AUTO_START=false
